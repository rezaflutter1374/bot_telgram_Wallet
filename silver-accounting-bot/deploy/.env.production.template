# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=CHANGE_ME

# Bot mode: auto | polling | webhook
BOT_MODE=auto

# Required when BOT_MODE=webhook
WEBHOOK_BASE_URL=https://bot.example.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=CHANGE_ME
WEBHOOK_TIMEOUT_SECONDS=10

# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/silver

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=100

# ─── Encryption ──────────────────────────────────────────────────────────────
# Fernet key — generate with: python scripts/generate_fernet_key.py
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_URLSAFE

# ─── Admin / Roles ───────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with super-admin privileges
SUPER_ADMIN_TELEGRAM_IDS=CHANGE_ME

# ─── Networking ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
METRICS_PATH=/metrics
HEALTH_PATH=/health

# ─── Time & Logging ──────────────────────────────────────────────────────────
TIMEZONE=Asia/Kabul
LOG_LEVEL=INFO

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_LIMIT=30
RATE_LIMIT_WINDOW_SECONDS=10

# ─── Pricing ─────────────────────────────────────────────────────────────────
PRICE_REFRESH_INTERVAL_SECONDS=30
PRICE_CACHE_TTL_SECONDS=5

PRICE_PROVIDER_PRIMARY=manual
PRICE_PROVIDER_SECONDARY=
PRICE_PROVIDER_TIMEOUT_SECONDS=10
PRICE_PROVIDER_MAX_RETRIES=2
PRICE_PROVIDER_STALE_AFTER_SECONDS=300
PRICE_PROVIDER_MIN_INTERVAL_SECONDS=10
PRICE_PROVIDER_MIN_PRICE_USD_PER_KG=100
PRICE_PROVIDER_MAX_PRICE_USD_PER_KG=1000000

# Metal price API keys (optional)
METALS_API_URL=https://metals-api.com/api/latest
METALS_API_KEY=
GOLDAPI_URL=https://www.goldapi.io/api/XAG/USD
GOLDAPI_KEY=

# ─── Batch Processing ────────────────────────────────────────────────────────
NOTIFICATION_BATCH_SIZE=100
WALLET_SCAN_BATCH_SIZE=500

# ─── Data Retention (days) ───────────────────────────────────────────────────
RETENTION_DAYS_SETTLEMENT=365
RETENTION_DAYS_AUDIT=730
RETENTION_DAYS_NOTIFICATIONS=90
RETENTION_DAYS_EXECUTION_REPORTS=180
RETENTION_DAYS_MARGIN_SNAPSHOTS=90
CLEANUP_BATCH_SIZE=1000

# ─── Circuit Breaker ─────────────────────────────────────────────────────────
CB_ERROR_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=60
CB_HALF_OPEN_MAX_CALLS=3

# ─── Dead Letter Queue ──────────────────────────────────────────────────────
DLQ_MAX_RETRIES=3

# ─── Settlement ──────────────────────────────────────────────────────────────
SETTLEMENT_LOCK_TTL_SECONDS=300

# ─── Margin / Liquidation ────────────────────────────────────────────────────
MARGIN_LIQUIDATION_CRITICAL_RATIO=0.50
MARGIN_CALL_THRESHOLD_RATIO=1.00
MARGIN_WARNING_RATIO=1.25

# ─── Monitoring ──────────────────────────────────────────────────────────────
# Grafana admin credentials (used by docker-compose.production.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ─── PostgreSQL (used by docker-compose.production.yml) ─────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=silver
